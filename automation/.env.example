# ─── Automation Microservice – .env.example ───────────────────────────────────
# Skopiuj do .env i uzupełnij wartości. NIE commituj pliku .env.

# Klucz API wymagany przez frontend do wywołań REST (min 32 znaki losowe)
AUTOMATION_API_KEY=change_me_generate_random_32_char_string

# Klucz Fernet do szyfrowania danych logowania (base64url, 32 bajty)
# Wygeneruj: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_run_fernet_generate_key

# Ścieżka do pliku z zaszyfrowanymi danymi logowania
CREDENTIALS_FILE=./data/credentials.enc

# Ścieżka do pliku audytu (JSON Lines)
AUDIT_LOG_FILE=./data/audit.log

# Czy uruchamiać Chrome w trybie headless (true/false)
HEADLESS=true

# Timeout sesji przeglądarki w sekundach
BROWSER_TIMEOUT=30

# Maksymalna liczba jednoczesnych sesji
MAX_CONCURRENT_SESSIONS=3

# Port serwera
PORT=8001

# URL serwisu z frontendem (dla CORS)
FRONTEND_URL=http://localhost:3000

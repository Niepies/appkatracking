# --- Automation Microservice - .env.example -----------------------------------
# Skopiuj do .env i uzupelnnij wartosci. NIE commituj pliku .env.

# Klucz API wymagany przez frontend do wywolan REST
# Musi byc identyczny jak AUTOMATION_API_KEY w web_app/.env.local
AUTOMATION_API_KEY=change_me_generate_random_string

# Sciezka do pliku audytu (JSON Lines)
AUDIT_LOG_FILE=./data/audit.log

# Czy uruchamiac Chrome w trybie headless (true = bez okna, false = z oknem)
# Ustaw false - reczne logowanie wymaga okna przegladarki
HEADLESS=false

# Timeout sesji przegladarki w sekundach
BROWSER_TIMEOUT=30

# Maksymalna liczba jednoczesnych sesji
MAX_CONCURRENT_SESSIONS=3

# Port serwera
PORT=8001

# URL serwisu z frontendem (dla CORS)
FRONTEND_URL=http://localhost:3000
